# Viewer environment configuration
# Copy this file to .env and adjust the paths for your local setup.

# Directory that contains your .jsonl asset manifest files
# VIEWER_ASSET_MANIFESTS_DIR=/path/to/your/data/assets

# Path to the primary asset manifest .jsonl file
# Defaults to <VIEWER_ASSET_MANIFESTS_DIR>/assets_manifest.jsonl
# VIEWER_ASSET_MANIFEST_PATH=/path/to/your/data/assets/my_manifest.jsonl

# Colon-separated list of additional directories to scan for .jsonl manifests (optional)
# VIEWER_EXTRA_MANIFEST_DIRS=/path/to/extra/dir1:/path/to/extra/dir2

# Additional allowed root directories the dev server is permitted to serve files from
# (colon-separated, optional — manifest dirs are always included)
# ROADGEN_VIEWER_ALLOWED_ROOTS=/some/external/cache
